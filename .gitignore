# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# cloudflare / opennext build output
/.open-next/
/.wrangler/

# misc
.DS_Store
*.pem

# heavy regenerable sample media (GIF/MP4 previews) — keep the repo light
/public/gifs/

# throwaway engine-test renders (neck/prompt experiments) — regenerable, not shipped
/public/necktest-v2/
/public/necktest-v3/
/public/neutral/
/public/neutral-test/
/public/guidance-test/
/public/v4-test/
/public/v5-test/
/public/chips-test/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
# wrangler/OpenNext local preview secrets (not matched by .env*)
.dev.vars
.dev.vars.*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
/public/bestof/

# v13 LoRA training pipeline (regenerable, heavy) — dataset frames + eval grids
/scripts/train-data/dataset-v13/
/scripts/test/eval/

# local-only: archived training artifacts (delete when ready) + kept reference samples
_trash_archive/
reference-samples/

# generated master candidates (scratch — the winner lands in public/brand/canonical/)
/scripts/out/
